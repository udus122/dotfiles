  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Needs Review - Claude Code' -activate 'com.microsoft.VSCode'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Done Tasks - Claude Code' -activate 'com.microsoft.VSCode'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE_PATH=$(jq -r '.tool_input.file_path') && ([ \"$(tail -c1 \"$FILE_PATH\" | wc -l)\" -eq 0 ] && echo >> \"$FILE_PATH\" || true)"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "language": "Japanese",
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "high"
}
